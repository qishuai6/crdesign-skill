  "typography": {
    "fontFamily": {
      "web": "\"PingFang SC\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    "scale": {
      "h1": { "size": 36, "lineHeight": 44, "weight": 500 },
      "h2": { "size": 32, "lineHeight": 40, "weight": 500 },
      "h3": { "size": 24, "lineHeight": 32, "weight": 500 },
      "h4": { "size": 18, "lineHeight": 26, "weight": 500 },
      "h5": { "size": 16, "lineHeight": 24, "weight": 500 },
      "h6": { "size": 14, "lineHeight": 22, "weight": 500 },
      "body": { "size": 14, "lineHeight": 22, "weight": 400 },
      "caption": { "size": 12, "lineHeight": 20, "weight": 400 }
    }
  },
  "radius": {
    "tokens": {
      "cr-radius-xs": "2px",
      "cr-radius-sm": "4px",
      "cr-radius-md": "6px",
      "cr-radius-lg": "8px",
      "cr-radius-xl": "12px",
      "cr-radius-2xl": "16px",
      "cr-radius-3xl": "24px"
    },
    "rule": "must be multiples of 2"
  },
  "shadow": {
    "cr-shadow-1": "0 1px 2px 0 rgba(0, 0, 0, 0.03), 0 1px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px 0 rgba(0, 0, 0, 0.02)",
    "cr-shadow-2": "0 6px 16px 0 rgba(0, 0, 0, 0.08), 0 3px 6px -4px rgba(0, 0, 0, 0.12), 0 9px 28px 8px rgba(0, 0, 0, 0.05)",
    "cr-shadow-3": "0 6px 16px 0 rgba(0, 0, 0, 0.32), 0 3px 6px -4px rgba(0, 0, 0, 0.12), 0 9px 28px 8px rgba(0, 0, 0, 0.05)"
  },
  "spacing": {
    "baseUnit": 4,
    "rhythmUnit": 8,
    "tokens": {
      "space-1": "4px",
      "space-2": "8px",
      "space-3": "12px",
      "space-4": "16px",
      "space-5": "20px",
      "space-6": "24px",
      "space-7": "32px",
      "space-8": "40px",
      "space-9": "48px",
      "space-10": "64px"
    },
    "pageVerticalRhythm": {
      "titleToSubtitle": "8px",
      "headerToContent": "24px",
      "groupToGroup": "24px",
      "cardToCard": ["16px", "24px"],
      "filtersToTable": ["16px", "24px"],
      "pageEnd": ["40px", "48px"]
    },
    "componentSpacing": {
      "buttonGroup": "12px",
      "tagGroup": "8px",
      "formItems": ["16px", "24px"],
      "toolbarControls": ["8px", "12px"],
      "cardList": ["16px", "24px"],
      "mediaModule": ["16px", "24px"],
      "chartCards": "24px"
    },
    "forbiddenValues": ["5px", "7px", "13px", "18px"]
  },
  "layout": {
    "container": {
      "layout-content-narrow": "960px",
      "layout-content-default": "1200px",
      "layout-content-wide": "1360px",
      "layout-content-fluid": "100%"
    },
    "pagePadding": {
      "layout-page-padding-desktop-sm": "24px",
      "layout-page-padding-desktop-md": "32px",
      "layout-page-padding-desktop-lg": "40px",
      "layout-page-padding-narrow": "20px",
      "layout-page-padding-narrow-lg": "24px"
    },
    "grid": {
      "grid-columns-marketing": 12,
      "grid-columns-system": 24,
      "grid-gutter-sm": "16px",
      "grid-gutter-md": "24px",
      "grid-gutter-lg": "32px"
    },
    "layoutRatios": {
      "twoColumn": ["6:6", "8:4", "9:3"],
      "threeColumn": ["4:4:4", "6:9:9"],
      "workbench": ["5:19", "6:18"],
      "formDetail": ["8:16", "12:12"]
    }
  },
  "breakpoints": {
    "xs": "<576px",
    "sm": ">=576px",
    "md": ">=768px",
    "lg": ">=992px",
    "xl": ">=1200px",
    "xxl": ">=1440px"
  },
  "responsiveRules": [
    "narrow viewports should collapse columns before shrinking page padding",
    "compress module spacing before compressing outer page margin",
    "complex tables may switch to card layouts in narrow viewports",
    "chart sections may reduce parallel columns in narrow viewports",
    "action areas should preserve primary action and weaken secondary action first"
  ]
}
